# Optional: sync waiver state across browsers via Firestore (honor-system; use restrictive rules in production).
# Copy to .env.local and fill from Firebase Console → Project settings → Your apps → Web app config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Optional: must match the region of callable `adminSyncMatchScores` (default asia-south1).
# VITE_FIREBASE_FUNCTIONS_REGION=asia-south1

# Optional: where league JSON is loaded when Firebase is configured.
# auto = Firestore iplFantasy/leagueBundle; if missing, fall back to static JSON (shows a Home warning).
# firestore = Firestore only (recommended for production after first publish — avoids stale static JSON vs waivers).
# static = always load from public/.../data/*.json (do not use with Firebase waivers/scoring; split-brain risk).
# VITE_LEAGUE_SOURCE=firestore

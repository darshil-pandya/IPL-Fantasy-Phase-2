{
  "name": "ipl-fantasy-phase-2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist/IPL-Fantasy-Phase-2",
    "build:waiver-pool": "python scripts/build_waiver_pool.py",
    "map-espn-squads": "npx tsx scripts/mapEspnSquadsToLeague.ts",
    "audit-scorecard-names": "npx tsx scripts/auditScorecardNameMapping.ts",
    "merge-scorecard-audit-into-espn-map": "npx tsx scripts/mergeScorecardAuditIntoEspnNameMap.ts",
    "reset:player-fantasy-json": "node scripts/reset-player-fantasy-json.mjs",
    "firestore:clear-match-scores": "npx firebase-tools@13 firestore:delete iplFantasy/fantasyMatchScores -f --project ipl-fantasy-phase-2",
    "backfill:dry-run-april2026": "npx tsx scripts/dryRunBackfillApril2026.ts",
    "export:match-sheets": "tsx scripts/exportFirestoreMatchSheets.ts"
  },
  "dependencies": {
    "firebase": "^11.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "firebase-admin": "^12.7.0",
    "gh-pages": "^6.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.4"
  }
}
